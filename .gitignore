# .gitignore for TaskFlow monorepo
# --------------------------------------------------
# General OS files
.DS_Store
Thumbs.db

# Node.js dependencies (client and server)
node_modules/

# Environment variable files (sensitive data)
.env
.env.*

# Build output directories
# Client (Vite) build output
client/dist/
client/build/

# Server build/output (if any)
server/dist/
server/build/

# Log files
npm-debug.log*
 yarn-debug.log*
 yarn-error.log*
logs/

# IDE / editor specific files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Test coverage reports
coverage/
.nyc_output/

# Miscellaneous
*.local
*.log

# End of .gitignore
