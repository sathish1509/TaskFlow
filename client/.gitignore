# Client .gitignore for React + Tailwind
# Node modules
node_modules/

# Build output directories
dist/
build/

# Environment variable files (sensitive data)
.env
.env.*

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# IDE / editor specific files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Miscellaneous
*.log
